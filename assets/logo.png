# Create a simple logo file - run this script once to generate logo.png
import base64
from PIL import Image
import io

logo_data = ""

img_data = base64.b64decode(logo_data)
img = Image.open(io.BytesIO(img_data))

import os
if not os.path.exists("assets"):
    os.makedirs("assets")
img.save("assets/logo.png")
print("Logo créé dans le dossier assets/")